</TestAction><hashTree><JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="InitTr" enabled="true">
  <stringProp name="cacheKey">True</stringProp>
  <stringProp name="filename"></stringProp>
  <stringProp name="parameters"></stringProp>
  <stringProp name="script">vars.put(&quot;GP&quot;,&quot;TR01&quot;)
</stringProp>
  <stringProp name="scriptLanguage">groovy</stringProp>
</JSR223PreProcessor><hashTree/><JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="StartTrVars" enabled="true">
  <stringProp name="cacheKey">True</stringProp>
  <stringProp name="filename"></stringProp>
  <stringProp name="parameters"></stringProp>
  <stringProp name="script">def duration = System.currentTimeMillis().toString()
def gpName = vars.get(&quot;GP&quot;)
vars.put(&quot;START&quot;,duration)
Long tot = vars.get(&quot;DUREE_&quot;+gpName).toLong()
vars.put(&quot;TOT&quot;,tot.toString())
Long min = vars.get(&quot;DUREE_&quot;+gpName+&quot;_MIN&quot;).toLong()
Long dE = 100
if ( min &lt; tot ) {
Long nbe = Math.max( 1L, vars.get(&quot;NBE_&quot;+gpName).toLong())
Long dT = Math.round((tot-min) * ( 1.05 -( 0.1 * Math.random()) ))
dE =  Math.round( dT / (nbe+1) )
}
vars.put(&quot;ETP&quot;,dE.toString())
</stringProp>
  <stringProp name="scriptLanguage">groovy</stringProp>
</JSR223PreProcessor><hashTree/></hashTree><kg.apc.jmeter.control.ParameterizedController guiclass="kg.apc.jmeter.control.ParameterizedControllerGui" testclass="kg.apc.jmeter.control.ParameterizedController" testname="_StartTrFiles" enabled="true">
