            <JSR223Timer guiclass="TestBeanGUI" testclass="JSR223Timer" testname="_Elapsed" enabled="true">
              <stringProp name="cacheKey">True</stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="script">def start=vars.get(&quot;START&quot;).toLong()
def tot=vars.get(&quot;TOT&quot;).toLong()
def End = System.currentTimeMillis()
def elapsed=End-start
def waitPacing=0
if(elapsed &lt; tot) {waitPacing = tot-elapsed}
return waitPacing
			  </stringProp>
              <stringProp name="scriptLanguage">groovy</stringProp>
            </JSR223Timer>
