    <stringProp name="0">Test Plan</stringProp><stringProp name="1">locimmo_Web_Workload</stringProp><stringProp name="2">TRANSACTIONS</stringProp><stringProp name="3">TR01_cycle_vie_annonce_bailleur</stringProp>
  </collectionProp>
</ModuleController><hashTree/></hashTree><TestFragmentController guiclass="TestFragmentControllerGui" testclass="TestFragmentController" testname="FONCTIONS_INTERNES" enabled="false"/><hashTree><GenericController guiclass="LogicControllerGui" testclass="GenericController" testname="ErrorLog" enabled="true"/><hashTree><JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="#ErrorLog" enabled="true">
  <stringProp name="scriptLanguage">groovy</stringProp>
  <stringProp name="parameters"></stringProp>
  <stringProp name="filename"></stringProp>
  <stringProp name="cacheKey">true</stringProp>
  <stringProp name="script">import org.apache.jmeter.services.FileServer
import  java.io.File
import  java.io.Writer
import java.time.LocalDateTime
import java.time.format.DateTimeFormatter
LocalDateTime Date = LocalDateTime.now()
DateTimeFormatter formatter = DateTimeFormatter.ofPattern(&quot;yyyy/MM/dd HH:mm:ss.SSS&quot;)
String timestamp = Date.format(formatter)
Long iter= vars.getIteration()
Integer thrnum = ctx.getThreadNum()+1
String url = prev.getUrlAsString()
String code = prev.getResponseCode()
String message = prev.getResponseMessage()
String failure = prev.getFirstAssertionFailureMessage()
String data = prev.getResponseDataAsString()
String file = vars.get(&quot;WORK&quot;)+&quot;/data/&quot;+ vars.get(&quot;FERR&quot;)
String gp = vars.get(&quot;GP&quot;)
Long nT = ctx.getThreadGroup().getNumThreads()
String gpName = ctx.getThreadGroup().getName()
Long cpt = (iter -1)*nT+thrnum
String line = timestamp + ',' +gpName+ ','+ cpt + ',' +  '${param}' +  ',' + url + ',' + code + ',' + message + ',' + failure +  '\n'
BufferedWriter out = new BufferedWriter(new OutputStreamWriter(new FileOutputStream(file+&quot;-&quot;+gp+&quot;_errors.csv&quot;, true), &quot;UTF-8&quot;))
out.write(line)
out.close()
line = timestamp + '--------- '+gpName +' iteration:' + cpt.toString() + ' param:' +  '${param}' + ' ----------\n'
BufferedWriter outData = new BufferedWriter(new OutputStreamWriter(new FileOutputStream(file+&quot;-&quot;+gp+&quot;_errors.data&quot;, true), &quot;UTF-8&quot;))
outData.write(line)
outData.write(data+'\n')
outData.close()
SampleResult.setSuccessful(false)
</stringProp>
</JSR223Sampler><hashTree/></hashTree><GenericController guiclass="LogicControllerGui" testclass="GenericController" testname="StartTrFiles" enabled="true"/><hashTree><JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="#StartTrFiles" enabled="true">
  <stringProp name="scriptLanguage">groovy</stringProp>
  <stringProp name="parameters"></stringProp>
  <stringProp name="filename"></stringProp>
  <stringProp name="cacheKey">true</stringProp>
  <stringProp name="script">import org.apache.jmeter.services.FileServer
import java.io.FileWriter
import java.io.File
import java.nio.charset.StandardCharsets
if ('${gp}'!='TRXX') {
	def duration = System.currentTimeMillis().toString()
	var fileName = vars.get(&quot;WORK&quot;)+&quot;/data/&quot;+ vars.get(&quot;FERR&quot;)
	def filePath = fileName+&quot;-&quot;+'${gp}'+&quot;_errors.csv&quot;
	def file = new File(filePath)
	if (!file.exists()) {
		String title =&quot;timestamp,threadgroup,cpt,data,url,code,message,failure\n&quot;
		try  (var errorFile = new FileWriter(fileName+&quot;-&quot;+'${gp}'+&quot;_errors.csv&quot;, StandardCharsets.UTF_8)) { errorFile.write(title)}
		try  (var dataFile = new FileWriter(fileName+&quot;-&quot;+'${gp}'+&quot;_errors.data&quot;, StandardCharsets.UTF_8)) { dataFile.write(&quot;&quot;)}
	}
}
</stringProp>
</JSR223Sampler><hashTree/></hashTree></hashTree><TestFragmentController guiclass="TestFragmentControllerGui" testclass="TestFragmentController" testname="FONCTIONS" enabled="false"/><hashTree><GenericController guiclass="LogicControllerGui" testclass="GenericController" testname="inscription" enabled="true"/><hashTree><HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="inscription-0001" enabled="true">
