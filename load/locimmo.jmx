        <GenericController guiclass="LogicControllerGui" testclass="GenericController" testname="_StartTr" enabled="true"/>
          <hashTree>
            <TestAction guiclass="TestActionGui" testclass="TestAction" testname="_InitTr" enabled="true">
              <intProp name="ActionProcessor.action">1</intProp>
              <intProp name="ActionProcessor.target">0</intProp>
              <stringProp name="ActionProcessor.duration">0</stringProp>
            </TestAction>
            <hashTree>
              <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="InitTr" enabled="true">
                <stringProp name="cacheKey">True</stringProp>
                <stringProp name="filename"></stringProp>
                <stringProp name="parameters"></stringProp>
                <stringProp name="script">vars.put(&quot;GP&quot;,&quot;TR01&quot;)
//donnee a inscrire dans le log en cas d&apos;erreur
//vars.put(&quot;data&quot;,&quot;test01&quot;)
			     </stringProp>
                <stringProp name="scriptLanguage">groovy</stringProp>
              </JSR223PreProcessor>
              <hashTree/>
              <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="StartTrVars" enabled="true">
                <stringProp name="scriptLanguage">groovy</stringProp>
                <stringProp name="parameters"></stringProp>
                <stringProp name="filename"></stringProp>
                <stringProp name="cacheKey">True</stringProp>
                <stringProp name="script">def duration = System.currentTimeMillis().toString()
def gpName = vars.get(&quot;GP&quot;)
vars.put(&quot;START&quot;,duration)
Long tot = vars.get(&quot;DUREE_&quot;+gpName).toLong()
vars.put(&quot;TOT&quot;,tot.toString())
Long min = vars.get(&quot;DUREE_&quot;+gpName+&quot;_MIN&quot;).toLong()
Long dE = 100
if ( min &lt; tot ) {
Long nbe = Math.max( 1L, vars.get(&quot;NBE_&quot;+gpName).toLong())
Long dT = Math.round((tot-min) * ( 1.05 -( 0.1 * Math.random()) ))
dE =  Math.round( dT / (nbe+1) )
}
vars.put("ETP",dE.toString())
                </stringProp>
              </JSR223PreProcessor>
              <hashTree/>
            </hashTree>
            <kg.apc.jmeter.control.ParameterizedController guiclass="kg.apc.jmeter.control.ParameterizedControllerGui" testclass="kg.apc.jmeter.control.ParameterizedController" testname="_StartTrFiles" enabled="true">
              <elementProp name="ParameterizedController" elementType="Arguments" guiclass="ArgumentsPanel" testclass="Arguments" testname="User Defined Variables" enabled="true">
