        <hashTree>
          <TestAction guiclass="TestActionGui" testclass="TestAction" testname="_InitTr" enabled="true">
            <intProp name="ActionProcessor.action">1</intProp>
            <intProp name="ActionProcessor.target">0</intProp>
            <stringProp name="ActionProcessor.duration">0</stringProp>
          </TestAction>
          <hashTree>
            <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="InitTr" enabled="true">
              <stringProp name="cacheKey">True</stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="script">vars.put("GP","TR1")</stringProp>
              <stringProp name="scriptLanguage">groovy</stringProp>
            </JSR223PreProcessor>
            <hashTree/>
            <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="StartTrVars" enabled="true">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="cacheKey">True</stringProp>
              <stringProp name="script">def duration = System.currentTimeMillis().toString()
def gpName = vars.get("GP")
vars.put("START",duration)
Long tot = vars.get("DUREE_"+gpName).toLong()
vars.put("TOT",tot.toString())
Long min = vars.get("DUREE_"+gpName+"_MIN").toLong()
Long dE = 100
if ( min &lt; tot ) {
Long nbe = Math.max( 1L, vars.get("NBE_"+gpName).toLong())
Long dT = Math.round((tot-min) * ( 1.05 -( 0.1 * Math.random()) ))
dE =  Math.round( dT / (nbe+1) )
}
vars.put("ETP",dE.toString())</stringProp>
            </JSR223PreProcessor>
            <hashTree/>
          </hashTree>
