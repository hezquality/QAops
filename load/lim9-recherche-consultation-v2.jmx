          <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="depot-0001" enabled="true">
                    <elementProp name="HTTPsampler.Arguments" elementType="Arguments" guiclass="HTTPArgumentsPanel" testclass="Arguments" enabled="true">
                      <collectionProp name="Arguments.arguments">
                        <elementProp name="" elementType="HTTPArgument">
                          <boolProp name="HTTPArgument.always_encode">false</boolProp>
                          <stringProp name="Argument.value">{&quot;title&quot;:&quot;Appartement charge ${ville}&quot;,&quot;description&quot;:&quot;Annonce generee pour le tir de charge LIM-9&quot;,&quot;type&quot;:&quot;apartment&quot;,&quot;price&quot;:900,&quot;city&quot;:&quot;${ville}&quot;,&quot;address&quot;:&quot;1 rue de la Charge&quot;,&quot;rooms&quot;:3,&quot;surface&quot;:65,&quot;furnished&quot;:true}</stringProp>
