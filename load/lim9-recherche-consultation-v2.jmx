      <TestFragmentController guiclass="TestFragmentControllerGui" testclass="TestFragmentController" testname="FONCTIONS_INTERNES" enabled="false"/>
      <hashTree>
        <GenericController guiclass="LogicControllerGui" testclass="GenericController" testname="ErrorLog" enabled="true"/>
        <hashTree>
          <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="#ErrorLog" enabled="true">
                      <stringProp name="scriptLanguage">groovy</stringProp>
                      <stringProp name="parameters"></stringProp>
                      <stringProp name="filename"></stringProp>
                      <stringProp name="cacheKey">true</stringProp>
                      <stringProp name="script">import org.apache.jmeter.services.FileServer
          import  java.io.File
          import  java.io.Writer
          import java.time.LocalDateTime
          import java.time.format.DateTimeFormatter
          LocalDateTime Date = LocalDateTime.now()
          DateTimeFormatter formatter = DateTimeFormatter.ofPattern(&quot;yyyy/MM/dd HH:mm:ss.SSS&quot;)
          String timestamp = Date.format(formatter)
          Long iter= vars.getIteration()
          Integer thrnum = ctx.getThreadNum()+1
          String url = prev.getUrlAsString()
          String code = prev.getResponseCode()
          String message = prev.getResponseMessage()
          String failure = prev.getFirstAssertionFailureMessage()
          String data = prev.getResponseDataAsString()
          String file = vars.get(&quot;WORK&quot;)+&quot;/data/&quot;+ vars.get(&quot;FERR&quot;)
          String gp = vars.get(&quot;GP&quot;)
          Long nT = ctx.getThreadGroup().getNumThreads()
          String gpName = ctx.getThreadGroup().getName()
          Long cpt = (iter -1)*nT+thrnum
          String line = timestamp + &apos;,&apos; +gpName+ &apos;,&apos;+ cpt + &apos;,&apos;+ &apos;${param}&apos; +  &apos;,&apos; + url + &apos;,&apos; + code + &apos;,&apos; + message + &apos;,&apos; + failure +  &apos;\n&apos;
          BufferedWriter out = new BufferedWriter(new OutputStreamWriter(new FileOutputStream(file+&quot;-&quot;+gp+&quot;_errors.csv&quot;, true), &quot;UTF-8&quot;))
          out.write(line)
          out.close()
          line = timestamp + &apos;--------- &apos;+gpName +&apos; iteration:&apos; + cpt.toString() + &apos; param:&apos; +  &apos;${param}&apos; + &apos; ----------\n&apos;
          BufferedWriter outData = new BufferedWriter(new OutputStreamWriter(new FileOutputStream(file+&quot;-&quot;+gp+&quot;_errors.data&quot;, true), &quot;UTF-8&quot;))
          outData.write(line)
          outData.write(data+&apos;\n&apos;)
          outData.close()
          SampleResult.setSuccessful(false)
                              </stringProp>
                    </JSR223Sampler>
          <hashTree/>
        </hashTree>
        <GenericController guiclass="LogicControllerGui" testclass="GenericController" testname="StartTrFiles" enabled="true"/>
        <hashTree>
          <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="#StartTrFiles" enabled="true">
                      <stringProp name="scriptLanguage">groovy</stringProp>
                      <stringProp name="parameters"></stringProp>
                      <stringProp name="filename"></stringProp>
                      <stringProp name="cacheKey">true</stringProp>
                      <stringProp name="script">import org.apache.jmeter.services.FileServer
          import java.io.FileWriter
          import java.io.File
          import java.nio.charset.StandardCharsets
          if (&apos;${gp}&apos;!=&apos;TRXX&apos;) {
          	def duration = System.currentTimeMillis().toString()
          	var fileName = vars.get(&quot;WORK&quot;)+&quot;/data/&quot;+ vars.get(&quot;FERR&quot;)
          	def filePath = fileName+&quot;-&quot;+&apos;${gp}&apos;+&quot;_errors.csv&quot;
          	def file = new File(filePath)
          	if (!file.exists()) {
          		String title =&quot;timestamp,threadgroup,cpt,data,url,code,message,failure\n&quot;
          		try  (var errorFile = new FileWriter(fileName+&quot;-&quot;+&apos;${gp}&apos;+&quot;_errors.csv&quot;, StandardCharsets.UTF_8)) { errorFile.write(title)}
          		try  (var dataFile = new FileWriter(fileName+&quot;-&quot;+&apos;${gp}&apos;+&quot;_errors.data&quot;, StandardCharsets.UTF_8)) { dataFile.write(&quot;&quot;)}
          	}
          }
          			 </stringProp>
                    </JSR223Sampler>
          <hashTree/>
        </hashTree>
      </hashTree>
